# =====================================================
# Angel's Baking Portfolio — Environment Variables
# =====================================================
# Copy this file to .env and fill in your values.

# Vercel Blob (REQUIRED for uploads, updates, and deletes in Studio)
# Get this from your Vercel project → Storage → Blob → Create Blob Store → copy the READ_WRITE token.
# IMPORTANT: Do NOT prefix with VITE_. This token must stay server-side only.
VERCEL_BLOB_READ_WRITE_TOKEN=your_vercel_blob_read_write_token_here

# Studio password (REQUIRED for admin access)
# Choose something strong. This is a simple client-side gate only.
VITE_STUDIO_PASSWORD=your-strong-studio-password-here
